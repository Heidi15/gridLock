{
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "prefer-const": "error",
    "no-var": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error", "log"] }],
    "eqeqeq": "error",
    "curly": "error",
    "no-warning-comments": ["warn", { "terms": ["todo", "fixme"], "location": "start" }]
  }
}
